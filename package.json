  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build --output server && node -e \"const fs=require('fs');fs.rmSync('dist/server/wrangler.json',{force:true});fs.rmSync('.wrangler',{recursive:true,force:true});\"",
    "deploy": "npm run build && wrangler deploy ./dist/server/index.js",
    "preview": "wrangler pages dev ./dist",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.3",
    "@klass/core": "4.0.0-next.30",
    "@klass/react": "^4.0.0-next.30",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "astro": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
